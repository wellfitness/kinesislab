# KinesisLab - Cache headers
<IfModule mod_headers.c>
  # HTML: no cachear agresivamente (revalidar siempre)
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # CSS/JS: cache 1 semana
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # Imagenes: cache 1 mes
  <FilesMatch "\.(png|jpg|jpeg|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# LiteSpeed Cache: desactivar para HTML
<IfModule LiteSpeed>
  CacheLookup off
</IfModule>
